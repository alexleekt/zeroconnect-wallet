{
  "manifest_version": 2,
  "name": "ZeroConnectWallet",
  "version": "1.0.3",
  "description": "A read-only wallet extension that mimics MetaMask for connecting to DeFi apps without storing private keys.",
  "browser_specific_settings": {
    "gecko": {
      "id": "zeroconnect-wallet@wafflepanda.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "assets/icon-48.png",
    "96": "assets/icon-96.png"
  },
  "permissions": ["storage", "notifications", "activeTab", "<all_urls>"],
  "browser_action": {
    "default_icon": {
      "48": "assets/icon-48.png",
      "96": "assets/icon-96.png"
    },
    "default_title": "ZeroConnectWallet",
    "default_popup": "popup/index.html"
  },
  "background": {
    "page": "background/background.html",
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": ["content/injected.js"]
}
